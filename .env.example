# .env — TMDB API Key Configuration
# ─────────────────────────────────────────────────────────────
# This file is loaded by python-dotenv at startup.
# NEVER commit the actual .env file to Git (it is listed in .gitignore).
# ─────────────────────────────────────────────────────────────

TMDB_API_KEY=your_api_key_here
